{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "types": ["node"],
    "rootDir": ".",
    "noEmit": true
  },
  "include": ["src", "test", "scripts"],
  "exclude": ["node_modules", "dist"]
}
